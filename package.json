{
  "name": "speech-interpreter",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "prisma generate --schema prisma/schema.prisma && turbo build",
    "postbuild": "prisma migrate deploy --schema prisma/schema.prisma",
    "start": "pnpm --filter @speech-interpreter/web start",
    "lint": "turbo lint",
    "type-check": "tsc --noEmit -p apps/web/tsconfig.json",
    "test": "pnpm --filter @speech-interpreter/web exec vitest run",
    "db:check": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/db-check.ts",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "prisma:seed": "prisma db seed",
    "db:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.19",
    "prettier": "^3.7.4",
    "prisma": "6.19.3",
    "ts-node": "^10.9.2",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "^3.0.3"
  }
}
