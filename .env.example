# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/speech_interpreter?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="speech-interpreter"
