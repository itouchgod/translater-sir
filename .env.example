# Auth.js / NextAuth
AUTH_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email
EMAIL_FROM="Speech Interpreter <no-reply@example.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE="false"

# AI providers
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
ANTHROPIC_API_KEY=""
DEEPGRAM_API_KEY=""
ELEVENLABS_API_KEY=""
AI_TRANSLATION_MODEL="gpt-4o-mini"
AI_SUMMARY_MODEL="gpt-4o-mini"

# Realtime
ABLY_API_KEY=""
NEXT_PUBLIC_ABLY_CLIENT_KEY=""
NEXT_PUBLIC_WS_URL="ws://localhost:3000"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
