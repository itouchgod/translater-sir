{
  "framework": "nextjs",
  "buildCommand": "pnpm prisma migrate deploy --schema ../../prisma/schema.prisma && pnpm turbo build",
  "installCommand": "pnpm install",
  "outputDirectory": ".next",
  "regions": ["sin1"],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "translatersir.com"
        }
      ],
      "destination": "https://www.translatersir.com/$1",
      "permanent": true
    }
  ],
  "crons": []
}
